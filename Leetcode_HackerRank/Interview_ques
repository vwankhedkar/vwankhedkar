# Recursive function to generate combinations
def generate_combinations(elements, current, index):
    # Print the current combination if it's not empty
    if current:
        print(''.join(current))
    
    # Recursively generate combinations
    for i in range(index, len(elements)):
        current.append(elements[i])  # Include the current element
        generate_combinations(elements, current, i + 1)  # Move to the next index
        current.pop()  # Backtrack to explore other combinations

