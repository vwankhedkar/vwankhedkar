def selectionSort(numbers):
    size=len(numbers)
    for i in range(size):
        min = i
        tmp = numbers[i]
        for j in range(i+1, size):
            if (numbers[j]<numbers[min]):
                min = j

        numbers[i] = numbers[min]
        numbers[min] = tmp
    return numbers
    
