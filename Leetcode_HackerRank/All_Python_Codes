class Solution:
    def isMatch(self, s: str, p: str) -> bool:
        stack = []
        while s or p:
          if len(p) > 1 and p[1] == '*':
            while (s and p) and ((p[0] == '.') or (s[0] == p[0])):
              stack.append((s, p[2:]))
              s = s[1:]
            p = p[2:]
          elif (p and s and (p[0] == '.')) or (p and s and (p[0] == s[0])):
            p = p[1:]
            s = s[1:]
          elif len(stack) > 0:
            s, p = stack.pop(-1)
          else:
            return False
        return (not s) and (not p)
