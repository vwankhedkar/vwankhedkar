class Solution:
    def inorderTraversal(self, root: Optional[TreeNode]) -> List[int]:
        values = []
        stack = [root]
        while stack:
            top = stack[-1]
            stack.pop()

            if type(top) == int:
                values.append(top)
            elif top is not None:
                stack.append(top.right)
                stack.append(top.val)
                stack.append(top.left)
        return values
