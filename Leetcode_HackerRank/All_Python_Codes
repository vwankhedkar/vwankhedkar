import re
def duplicate_word(word):
    word_dir = {}
    for ch in word:
        if ch in word_dir: 
            word_dir[ch] += 1
        elif ch not in word_dir:
            word_dir[ch] = 1
    return replace(word, word_dir)

def replace(word, word_dir):
    for ch in word:
        if word_dir[ch] > 1:
            word = word.replace(ch, ")")
        elif word_dir[ch] == 1:
            word = word.replace(ch, '(')
    return word

