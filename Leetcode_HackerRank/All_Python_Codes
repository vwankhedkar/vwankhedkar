class Solution(object):
    def trap(self, height):
        """
        :type height: List[int]
        :rtype: int
        """
        totalWater = 0
        for p in range(len(height)):
            leftp, rightp, maxLeft, maxright = p, p, 0, 0 
            while (leftp >= 0):
                maxLeft = max(maxLeft, height[leftp])
                leftp -= 1

            while (rightp < len(height)):
                maxright = max(maxright, height[rightp])
                rightp += 1
            currentWater = min(maxLeft, maxright) - height[p]
            if currentWater > 0:
                totalWater += currentWater
        return totalWater
        
