class Solution:
    def deleteDuplicates(self, head: Optional[ListNode]) -> Optional[ListNode]:
        """
        :type head: ListNode
        :rtype: ListNode
        """
        # Assign two pointers
        slow = head
        fast = head
        # Make sure `fast` does not exceed the size of the list
        while fast != None:
            # Operations on `slow`
            if slow.val != fast.val:
                slow = slow.next
                slow.val = fast.val
            # `fast` moves one step to the right
            fast = fast.next
        # Break the list at the node where `slow` is at
        if slow != None:
            slow.next = None
        return head
