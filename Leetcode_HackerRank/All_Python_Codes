class Points(object):
    def __init__(self, x, y, z):
        self.x = x
        self.y = y
        self.z = z

    def __sub__(self, no):
        sub_val = Points(self.x-no.x,self.y-no.y,self.z-no.z)
        return sub_val

    def dot(self, no):
        dot_val = (self.x*no.x) + (self.y * no.y) + (self.z * no.z)
        return dot_val

    def cross(self, no):
        crossval = Points((self.y*no.z - self.z*no.y),(self.z*no.x - self.x*no.z),(self.x*no.y - self.y*no.x))
        return crossval
        
    def absolute(self):
        return pow((self.x ** 2 + self.y ** 2 + self.z ** 2), 0.5)

