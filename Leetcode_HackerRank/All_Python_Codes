    def __init__(self, numbers):
        self.numbers = numbers

    def bubSort(self):
        for i in range(len(self.numbers)-1):
            for j in range(len(self.numbers)-i-1):
                if self.numbers[j] > self.numbers[j+1]:
                    self.swap(j, j+1) 

