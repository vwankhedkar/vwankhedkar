class TreeAncestor:
    def __init__(self, n: int, parent: List[int]):
        children_num = [0] * n
        for i in range(1, n):
            p = parent[i]
            children_num[p] += 1
            
        node_path_map = {}
        paths = []
        for i, n in enumerate(children_num):
            if n > 0:
                continue
            # leaf node
            node = i
            path = []
            path_id = len(paths)
            node_index_in_path = -1
            while node != -1:
                path.append(node)
                node_index_in_path += 1
                node_path_map[node] = (path_id, node_index_in_path)
                node = parent[node]
            paths.append(path)
            
        self.node_path_map, self.paths = node_path_map, paths

    def getKthAncestor(self, node: int, k: int) -> int:
        path_id, node_index_in_path = self.node_path_map[node]
        path = self.paths[path_id]
        anscestor_index = node_index_in_path + k
        if anscestor_index >= len(path):
            return -1
        return path[anscestor_index]
        


