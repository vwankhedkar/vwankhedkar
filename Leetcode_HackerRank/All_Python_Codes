def count_substring(string, sub_string):
    counter, sum = 0, 0
    for _ in range(0, len(string)):
        if matcher(string[counter:(len(sub_string)+counter)], sub_string):
            sum = sum + 1
        counter = counter + 1
    return sum
def matcher(sliced_str, sub_string):
    return sliced_str == sub_string
